#!/usr/bin/env python3
# /// script
# requires-python = ">=3.10"
# dependencies = [
#     "pypdf>=5.0.0",
#     "pymupdf>=1.24.0",
# ]
# ///

import logging
import sys
import tempfile
from pathlib import Path
from pypdf import PdfWriter, PdfReader
from pypdf.errors import FileNotDecryptedError, PdfReadError
import fitz


logging.getLogger("pypdf").setLevel(logging.CRITICAL)

A4 = fitz.paper_rect("a4")
IMAGE_EXTENSIONS = {
    ".bmp",
    ".gif",
    ".jfif",
    ".jp2",
    ".jpe",
    ".jpeg",
    ".jpg",
    ".jpx",
    ".pam",
    ".pbm",
    ".pgm",
    ".png",
    ".pnm",
    ".ppm",
    ".psd",
    ".tif",
    ".tiff",
}


def die(message: str, code: int = 1) -> None:
    print(f"pdfcat: {message}", file=sys.stderr)
    raise SystemExit(code)


def fit_rect(src: fitz.Rect, dst: fitz.Rect) -> fitz.Rect:
    scale = min(dst.width / src.width, dst.height / src.height)
    width = src.width * scale
    height = src.height * scale
    x0 = dst.x0 + (dst.width - width) / 2
    y0 = dst.y0 + (dst.height - height) / 2
    return fitz.Rect(x0, y0, x0 + width, y0 + height)


def image_to_pdf(path: Path) -> Path:
    image = None
    converted = None
    pdf = None
    try:
        image = fitz.open(path)
        pdf = fitz.open()
        page = pdf.new_page(width=A4.width, height=A4.height)
        rect = image[0].rect
        converted = fitz.open("pdf", image.convert_to_pdf())
        page.show_pdf_page(fit_rect(rect, A4), converted, 0)
    except Exception as exc:
        die(f"invalid or unreadable image: {path}: {exc}")

    tmp = tempfile.NamedTemporaryFile(prefix="pdfcat-image-", suffix=".pdf", delete=False)
    tmp.close()
    out = Path(tmp.name)
    try:
        pdf.save(out)
    except OSError as exc:
        die(f"cannot convert image: {path}: {exc}")
    finally:
        if image is not None:
            image.close()
        if converted is not None:
            converted.close()
        if pdf is not None:
            pdf.close()
    return out


def append_pdf(writer: PdfWriter, path: Path, label: str) -> None:
    try:
        reader = PdfReader(str(path))
        if reader.is_encrypted:
            die(f"encrypted PDF requires a password: {label}")
        for page in reader.pages:
            writer.add_page(page)
    except FileNotDecryptedError:
        die(f"encrypted PDF requires a password: {label}")
    except PdfReadError as exc:
        die(f"invalid or unreadable PDF: {label}: {exc}")
    except OSError as exc:
        die(f"cannot read input: {label}: {exc}")


def main():
    if len(sys.argv) < 3:
        die("usage: pdfcat <output.pdf> <input1.pdf> [input2.pdf ...]", 2)

    output_file = sys.argv[1]
    input_files = sys.argv[2:]

    if not output_file.endswith(".pdf"):
        output_file += ".pdf"

    writer = PdfWriter()
    temp_files: list[Path] = []

    try:
        for input_path in input_files:
            path = Path(input_path)
            if not path.exists():
                die(f"input not found: {input_path}")
            if path.is_dir():
                die(f"input is a directory: {input_path}")

            print(f"Adding: {input_path}", file=sys.stderr)
            if path.suffix.lower() in IMAGE_EXTENSIONS:
                converted = image_to_pdf(path)
                temp_files.append(converted)
                append_pdf(writer, converted, input_path)
            else:
                append_pdf(writer, path, input_path)

        print(f"Writing: {output_file}", file=sys.stderr)
        try:
            with open(output_file, "wb") as f:
                writer.write(f)
        except OSError as exc:
            die(f"cannot write output: {output_file}: {exc}")

        print(f"Done: {len(input_files)} files merged -> {output_file}", file=sys.stderr)
    finally:
        for temp_file in temp_files:
            temp_file.unlink(missing_ok=True)


if __name__ == "__main__":
    main()
